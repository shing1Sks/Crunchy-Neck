# ─── Crunchy-Neck-Agent environment variables ────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# ─── Telegram comm-channel (ping_user) ───────────────────────────────────────
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=8747200948:AAH0cj7nHv0U-KcaQbbpC5KYqezhxur4y5A

# Chat ID of the conversation — used for ALL message types (update, chat,
# query:msg, query:options). This is typically your own user chat ID.
# To find it: message the bot directly, then call:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and look for "message" -> "chat" -> "id" in the response.
TELEGRAM_CHAT_ID=1253249648
