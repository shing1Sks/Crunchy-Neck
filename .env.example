# ─── Crunchy-Neck-Agent environment variables ────────────────────────────────
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# ─── OpenAI (crunchy-neck-agent: main model + compaction + session wrapup) ────
# Required for crunchy-neck-agent. Get your key from https://platform.openai.com/api-keys
# Model used: gpt-5.2 (reasoning_effort=low for all calls)
OPENAI_API_KEY=

# ─── Groq Cloud (open-crunchy-agent: Kimi K2 open-source model) ──────────────
# Required for open-crunchy-agent. Get your key from https://console.groq.com/keys
# Model used: moonshotai/kimi-k2-instruct-0905
GROQ_API_KEY=

# ─── Telegram comm-channel (ping_user) ───────────────────────────────────────
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Chat ID of the conversation — used for ALL message types (update, chat,
# query:msg, query:options). This is typically your own user chat ID.
# To find it: message the bot directly, then call:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and look for "message" -> "chat" -> "id" in the response.
TELEGRAM_CHAT_ID=

# ─── Inworld TTS (tts tool) ───────────────────────────────────────────────────
# Get your API key from https://platform.inworld.ai — it is already base64-encoded.
# Set as: INWORLD_API_KEY=<your-key>
INWORLD_API_KEY=

# ─── Google Gemini (image_gen tool) ───────────────────────────────────────────
# Get an API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
